---
import { getCollection } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

const docs = (await getCollection('docs')).sort(
  (left, right) => left.data.order - right.data.order,
);
---

<DocsLayout title="Docs — faltoo.bot">
  <header class="docs-header">
    <p class="section__eyebrow">Docs</p>
    <h1>Start with the command you need.</h1>
    <p>Install once, then run the WhatsApp bot or the local coding chat.</p>
  </header>

  <ul class="docs-index-list">
    {docs.map((entry) => (
      <li>
        <a href={`/docs/${entry.id.replace(/\.md$/, '')}/`}>
          <strong>{entry.data.title}</strong>
          {entry.data.description && <span>{entry.data.description}</span>}
        </a>
      </li>
    ))}
  </ul>
</DocsLayout>
