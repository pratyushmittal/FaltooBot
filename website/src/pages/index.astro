---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
---

<BaseLayout title="Mittals AI — A family of practical AI tools">
  <div class="page-shell">
    <section class="hero">
      <img
        class="hero__family"
        src="/plushies/family.png"
        alt="The Mittals AI family mascots"
        width="740"
        height="493"
      />
      <div class="hero__wash"></div>
      <Header />
      <div class="hero__content">
        <p class="hero__brand">Mittals AI</p>
        <h1>A small family of practical AI tools for chat, coding, and everyday work.</h1>
        <p class="hero__lede">
          Install the family once, then reach for the Mittal you need: Claw for WhatsApp,
          Coder for local coding work, and Recipes for the habits that make both sharper.
        </p>
        <div class="hero__actions">
          <a class="button button--primary" href="#install">Install with uv</a>
          <a class="button button--secondary" href="/docs/family-guide/">Read the family guide</a>
        </div>
        <div class="hero__command" id="install" aria-label="Install command">
          <span>$</span>
          <code>uv tool install mittals</code>
        </div>
      </div>
    </section>

    <main>
      <section class="feature feature--claw" id="claw">
        <div class="feature__media">
          <img src="/plushies/claw.png" alt="Claw Mittal plush mascot" width="740" height="493" />
        </div>
        <div class="feature__copy">
          <p class="section__eyebrow">Claw Mittal</p>
          <h2>The WhatsApp AI agent.</h2>
          <p>
            Claw Mittal handles the quick everyday work from the phone: replies, summaries,
            image-aware chats, and personal assistance from its own WhatsApp account.
          </p>
          <a class="text-link" href="/docs/claw-mittal/">Open the getting started guide</a>
        </div>
      </section>

      <section class="feature feature--coder" id="coder">
        <div class="feature__copy">
          <p class="section__eyebrow">Coder Mittal</p>
          <h2>The coding agent with review mode.</h2>
          <p>
            Coder Mittal works in the terminal. Its edge is review mode: inspect diffs, leave
            review comments, stage lines, and send the whole review back into chat.
          </p>
          <a class="text-link" href="/docs/coder-mittal/">Open the getting started guide</a>
        </div>
        <div class="feature__media">
          <img src="/plushies/coder.png" alt="Coder Mittal plush mascot" width="493" height="740" />
        </div>
      </section>

      <section class="section section--recipes" id="recipes">
        <div class="section__intro">
          <p class="section__eyebrow">Recipes</p>
          <h2>Workflows that make the family sharper.</h2>
          <p>
            Recipes are short playbooks: prompts, conventions, and workflows that help Claw
            Mittal and Coder Mittal do better work together.
          </p>
          <a class="text-link" href="/docs/recipes/">Read the recipes guide</a>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>
