    {
      "id": "HNxhkkOtd3vOL4IDDCCUP",
      "type": "text",
      "x": 1629.5159252430715,
      "y": 3188.027891126082,
      "width": 516.95947265625,
      "height": 140,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "at6BXvBCWglCK0i8iX3uD"
      ],
      "frameId": null,
      "index": "bOj",
      "roundness": null,
      "seed": 793658024,
      "version": 765,
      "versionNonce": 1852083624,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "9ZJy1K9fNA_HoPwdGQjjH",
          "type": "arrow"
        }
      ],
      "updated": 1774376905008,
      "link": null,
      "locked": false,
      "text": "this should help reduce config drift between callers\nfor example, whatsapp client calls build_config()\nsession.py also calls build_config() internally\nThis leads to multiple different configs during runtime since\nbuild_config() reads the file on each call.\nSuggestion here is to move to an immutable config that is loaded \non runtime and passed everywhere else.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "this should help reduce config drift between callers\nfor example, whatsapp client calls build_config()\nsession.py also calls build_config() internally\nThis leads to multiple different configs during runtime since\nbuild_config() reads the file on each call.\nSuggestion here is to move to an immutable config that is loaded \non runtime and passed everywhere else.",
      "autoResize": true,
      "lineHeight": 1.25
    },
